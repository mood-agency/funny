{
  "name": "@ironmussa/funny",
  "version": "0.1.2",
  "private": false,
  "description": "Codex App clone powered by Claude Code — parallel agent orchestration with git worktrees",
  "license": "MIT",
  "author": "Anthropic",
  "repository": {
    "type": "git",
    "url": "https://github.com/ironmussa/funny.git"
  },
  "bin": {
    "funny": "./bin/funny.js",
    "funny-server": "./packages/server/bin/funny-server.js",
    "funny-runtime": "./packages/runtime/bin/funny-server.js"
  },
  "workspaces": [
    "packages/*"
  ],
  "files": [
    "bin",
    "packages/runtime/dist",
    "packages/client/dist"
  ],
  "scripts": {
    "start": "bun ./bin/funny.js",
    "dev": "concurrently --kill-others -n server,runner,client -c blue,green,yellow \"bun run dev:server\" \"bun run dev:runtime\" \"bun run dev:client\"",
    "dev:server": "bun --env-file ../../.env --cwd packages/server --watch src/index.ts",
    "dev:runtime": "bun --env-file ../../.env --cwd packages/runtime src/index.ts",
    "dev:client": "cd packages/client && npx vite",
    "build": "bun run --cwd packages/client build && bun run --cwd packages/runtime build && bun run --cwd packages/server build",
    "build:railway": "bun install && bun run build",
    "start:railway": "cd packages/server && bun run start",
    "prepublishOnly": "npm run build",
    "db:push": "bun run --cwd packages/runtime db:push",
    "db:studio": "bun run --cwd packages/runtime db:studio",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "build:native": "bun run --cwd packages/native-git build",
    "build:native:debug": "bun run --cwd packages/native-git build:debug",
    "build:sidecar": "bun scripts/build-sidecar.ts",
    "test": "bun run --cwd packages/shared test && bun run --cwd packages/core test && bun run --cwd packages/agent test && bun run --cwd packages/runtime test && bun run --cwd packages/client test",
    "prepare": "husky",
    "security:check": "npm run security:secrets && npm run security:audit",
    "security:secrets": "npx secretlint \"**/*\"",
    "security:audit": "npx audit-ci --moderate",
    "security:snyk": "npx snyk test --all-projects",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test:e2e": "bunx playwright test",
    "test:e2e:ui": "bunx playwright test --ui",
    "codegen": "bunx playwright codegen http://localhost:5180"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@secretlint/secretlint-rule-preset-recommend": "^11.3.1",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "neverthrow": "^8.2.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "secretlint": "^11.3.1"
  },
  "optionalDependencies": {
    "@openai/codex-sdk": "^0.101.0",
    "node-pty": "^1.1.0",
    "playwright": "^1.50.0"
  },
  "resolutions": {
    "esbuild": ">=0.24.3"
  },
  "engines": {
    "bun": ">=1.3.5"
  }
}
