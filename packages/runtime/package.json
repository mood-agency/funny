{
  "name": "@ironmussa/funny-runtime",
  "version": "0.1.0",
  "private": false,
  "description": "Funny server runtime for agent orchestration, git workflows, and real-time updates.",
  "homepage": "https://github.com/ironmussa/funny/tree/main/packages/runtime",
  "bugs": {
    "url": "https://github.com/ironmussa/funny/issues"
  },
  "license": "MIT",
  "author": "Anthropic",
  "repository": {
    "type": "git",
    "url": "https://github.com/ironmussa/funny.git",
    "directory": "packages/runtime"
  },
  "bin": {
    "funny-server": "./bin/funny-server.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./app": "./src/app.ts",
    "./lib/auth": "./src/lib/auth.ts",
    "./services/server-interfaces": "./src/services/server-interfaces.ts",
    "./services/service-provider": "./src/services/service-provider.ts",
    "./services/service-registry": "./src/services/service-registry.ts",
    "./services/automation-manager": "./src/services/automation-manager.ts",
    "./services/mcp-oauth": "./src/services/mcp-oauth.ts",
    "./services/ws-broker": "./src/services/ws-broker.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun src/dev-watch.ts",
    "dev:test": "bun src/kill-port.ts 3008 && FUNNY_DATA_DIR=.funny-test PORT=3008 CLIENT_PORT=5180 bun --watch src/index.ts",
    "build": "bun run build.ts",
    "start": "bun run dist/index.js",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio",
    "test": "vitest run",
    "lint:promises": "eslint src/",
    "mcp:memory": "bun ../memory/src/mcp/server.ts",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@abbacchio/transport": "^0.2.0",
    "@anthropic-ai/claude-agent-sdk": "^0.2.42",
    "@anthropic-ai/sdk": "^0.78.0",
    "@funny/memory": "*",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "assemblyai": "^4.26.1",
    "better-auth": "^1.4.18",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.9",
    "nanoid": "^5.0.9",
    "neverthrow": "^8.2.0",
    "nodemailer": "^8.0.2",
    "pg": "^8.20.0",
    "postgres": "^3.4.8",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "winston-transport": "^4.9.0",
    "ws": "^8.19.0",
    "xstate": "^5.28.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@funny/core": "*",
    "@funny/pipelines": "*",
    "@funny/shared": "*",
    "@types/bun": "^1.3.8",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "@openai/codex-sdk": "^0.101.0",
    "node-pty": "^1.1.0",
    "playwright": "^1.50.0"
  },
  "engines": {
    "bun": ">=1.3.5"
  }
}
