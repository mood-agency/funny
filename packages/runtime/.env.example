# Server port
PORT=3005

# Host to bind the server (default: 127.0.0.1, use 0.0.0.0 for remote access)
HOST=0.0.0.0

# Client port (used for CORS origins)
CLIENT_PORT=5179

# Custom CORS origins (comma-separated, overrides default localhost origins)
CORS_ORIGIN=http://123.45.67.89:5173,http://mydomain.com:5173

# Authentication mode: 'local' (single user, no login) or 'multi' (multi-user with auth)
AUTH_MODE=local

# Database mode: 'sqlite' (default) or 'postgres'
# AUTH_MODE=multi requires DB_MODE=postgres
DB_MODE=sqlite

# PostgreSQL connection (required when DB_MODE=postgres)
# Option 1: Full URL
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# Option 2: Individual variables
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=secret
# DB_NAME=funny
# Option 3: Standard PG* vars (auto-set by Railway, Heroku, etc.)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=secret
# PGDATABASE=funny

# Explicit path to the Claude CLI binary (optional, overrides auto-detection)
CLAUDE_BINARY_PATH=/path/to/claude

# GitHub OAuth App client ID (required for "Clone from GitHub" feature)
# Create one at https://github.com/settings/applications/new (enable Device Flow)
GITHUB_CLIENT_ID=your_client_id_here

FUNNY_DATA_DIR=~/.funny-test
