{
  "name": "@funny/evflow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./generators": "./src/generators/index.ts",
    "./plugin": "./plugin/index.cjs"
  },
  "scripts": {
    "test": "bun test",
    "build:plugin": "bun build src/plugin/index.ts --outfile plugin/bundle.cjs --target node --format cjs --external typescript && bun run src/plugin/build-entry.ts",
    "viewer": "cd viewer && bun run dev",
    "viewer:build": "cd viewer && bun run build",
    "viewer:json": "bun run viewer/gen-json.ts"
  },
  "dependencies": {
    "neverthrow": "^8.2.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "typescript": "^5.8.2"
  }
}
