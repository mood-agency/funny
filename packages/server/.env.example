# Central server configuration

# PostgreSQL connection (required)
DATABASE_URL=postgresql://postgres:password@localhost:5432/funny_central

# Server
PORT=3002
HOST=0.0.0.0

# CORS origins (comma-separated)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Data directory for auth secrets and encryption keys (optional)
# FUNNY_CENTRAL_DATA_DIR=~/.funny-central

INGEST_WEBHOOK_SECRET=your-webhook-secret-here
