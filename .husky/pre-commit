#!/usr/bin/env sh

# Secret detection
git diff --cached --name-only --diff-filter=ACM | grep -v '^docker/' | xargs -r npx secretlint

# Format staged files (auto-fix and re-stage) — run BEFORE lint so format issues never block
STAGED_FMT=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx|css|json)$' | grep -v '^\.claude/' || true)
if [ -n "$STAGED_FMT" ]; then
  echo "$STAGED_FMT" | xargs npx oxfmt --write
  echo "$STAGED_FMT" | xargs git add
fi

# Lint staged JS/TS files (runs after format so code is already clean)
git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' | xargs -r npx oxlint

# Detect merge conflict markers (exclude hook scripts to avoid self-match)
CONFLICT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -v '^\.husky/' | xargs -r grep -l '<<<<<<<\|=======\|>>>>>>>' || true)
if [ -n "$CONFLICT_FILES" ]; then
  echo "Merge conflict markers found in:"
  echo "$CONFLICT_FILES"
  exit 1
fi

# Block console.log and debugger statements (exclude test files and podman-chrome-streaming runtime)
DEBUG_MATCHES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' | grep -v '__tests__/' | grep -v '\.test\.' | grep -v '\.spec\.' | grep -v 'packages/podman-chrome-streaming/' | xargs -r grep -n 'console\.log\|debugger' || true)
if [ -n "$DEBUG_MATCHES" ]; then
  echo "Debug statements found:"
  echo "$DEBUG_MATCHES"
  exit 1
fi
