#!/usr/bin/env sh

# Enforce conventional commits format
commit_msg=$(head -1 "$1")
if ! echo "$commit_msg" | grep -qE '^(feat|fix|chore|docs|style|refactor|test|ci|build|perf|revert)(\(.+\))?: .+'; then
  echo "Invalid commit message format."
  echo "Expected: type(scope): description"
  echo "Types: feat, fix, chore, docs, style, refactor, test, ci, build, perf, revert"
  exit 1
fi
